<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="40dp"
    android:paddingStart="40dp"
    tools:context=".view.stopWatch.StopWatchFragment">

    <TextView
        android:id="@+id/title"
        android:layout_width="45dp"
        android:layout_height="25dp"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:text="@string/stop_watch"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/edit"
        android:layout_width="50dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_edit_circle"
        android:contentDescription="更多"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/compose_view"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="40dp"

        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/stop_watch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginEnd="40dp"
        android:text="00:00.00"
        android:textSize="18sp"
        android:textColor="@color/black"

        app:layout_constraintTop_toBottomOf="@+id/compose_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/break_point"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="00:00.00"
        android:textSize="12sp"
        android:textColor="@color/black"
        android:layout_marginEnd="40dp"

        android:visibility="invisible"

        app:layout_constraintTop_toBottomOf="@+id/stop_watch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/laps"
        android:layout_width="match_parent"
        android:layout_height="200dp"

        android:layout_marginTop="10dp"
        android:layout_marginEnd="40dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_quick_note"

        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarSize="4dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"

        app:layout_constraintTop_toBottomOf="@id/break_point"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:src="@drawable/ic_begin"
        android:layout_marginBottom="20dp"
        app:borderWidth="0dp"
        android:layout_marginEnd="40dp"

        android:backgroundTint="@color/white"
        android:background="@color/white"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_left_stop_watch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:src="@drawable/ic_stop_watch"
        android:layout_marginBottom="20dp"
        app:borderWidth="0dp"

        android:backgroundTint="@color/white"
        android:background="@color/white"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:visibility="gone"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_right_stop_watch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:src="@drawable/ic_reopen"
        android:layout_marginBottom="20dp"
        app:borderWidth="0dp"

        android:backgroundTint="@color/white"
        android:background="@color/white"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>